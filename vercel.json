{
  "buildCommand": "",
  "outputDirectory": "public",
  "functions": {
    "api/heygen/upload.js": {
      "maxDuration": 60,
      "memory": 512
    },
    "api/**/*.js": {
      "maxDuration": 60
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
